{
     "version":"2.0.0",
     "tasks": [
          {
               "label": "Run Django Backend",
               "type": "shell",
               "command": "${workspaceFolder}/backend/.venv/Scripts/python.exe manage.py runserver",
               "options": {
                    "cwd": "${workspaceFolder}/backend/truthlens_backend"
               },
               "isBackground": true,
               "presentation": {
                    "group": "truthlens"
               }
          },
          {
               "label": "Run React Frontend",
               "type": "shell",
               "command": "npm run dev",
               "options": {
                    "cwd": "${workspaceFolder}/frontend/frontend"
               },
               "isBackground": true,
               "presentation": {
                    "group": "truthlens"
               }
          },
          {
               "label": "Run React Extension",
               "type": "shell",
               "command": "npm run dev",
               "options": {
                    "cwd": "${workspaceFolder}/extension"
               },
               "isBackground": true,
               "presentation": {
                    "group": "truthlens"
               }
          }
     ]
}